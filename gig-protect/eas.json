{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "github-release": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production"
      },
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {}
  }
}
